{
  "act_name": "Bharatiya Nyaya Sanhita, 2023",
  "act_short": "BNS",
  "effective_date": "2024-07-01",
  "description": "The Bharatiya Nyaya Sanhita (BNS) replaces the Indian Penal Code (IPC) of 1860. It codifies criminal law in India with updated provisions reflecting modern legal standards.",
  "key_changes_from_ipc": [
    "Community service introduced as a form of punishment",
    "Sedition law replaced with 'acts endangering sovereignty'",
    "New provisions for organized crime and terrorism",
    "Enhanced punishments for various offences",
    "Gender-neutral language in many sections"
  ],
